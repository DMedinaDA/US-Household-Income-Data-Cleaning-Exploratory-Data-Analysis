################################################################################
# 6. IDENTIFY MISSING LAND/WATER VALUES
################################################################################

SELECT ALand, AWater
From us_project.us_household_income  
WHERE (Awater = 0 OR Awater = '' OR Awater IS NULL) 
  AND (Aland = 0 OR Aland = '' OR Aland IS NULL);
