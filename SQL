################################################################################
# 2. REMOVE DUPLICATES (us_household_income)
################################################################################

Select id, COUNT(id)
From us_project.us_household_income
group by id
having COUNT(id) > 1;
## → Identify duplicate id values (if any)

SELECT *
FROM (
  Select row_id,
    id, 
    ROW_NUMBER() OVER (Partition by id order by id) AS row_num
  FROM us_project.us_household_income
) AS duplicates 
WHERE row_num > 1;
## → Show only the extra copies (row_num > 1) that need deletion

DELETE FROM us_household_income
WHERE row_id IN (
  SELECT row_id
  FROM (
    Select row_id,
      id, 
      ROW_NUMBER() OVER (Partition by id order by id) AS row_num
    FROM us_project.us_household_income
  ) AS duplicates 
  WHERE row_num > 1
);
## → Permanently delete all duplicate rows, keeping one per id

################################################################################
# 3. REMOVE DUPLICATES (us_household_income_statistics)
################################################################################

Select id, COUNT(id)
From us_project.us_household_income_statistics
group by id
having COUNT(id) > 1;
## → Check for duplicates in income table (none found in this dataset)

################################################################################
# 4. STANDARDIZE STATE & PLACE NAMES
################################################################################

Select DISTINCT State_Name
From us_project.us_household_income
order by 1;
## → Spot typos: 'georia', 'alabama' (lowercase), etc.

UPDATE us_project.us_household_income
SET state_name = 'Georgia'
WHERE state_name = 'georia';
## → Fix Georgia typo

UPDATE us_project.us_household_income
SET state_name = 'Alabama'
WHERE state_name = 'alabama';
## → Normalize Alabama to title case

Select DISTINCT State_ab
From us_project.us_household_income
order by 1;
## → Verify state abbreviations are consistent

Select *
From us_project.us_household_income
WHERE County = 'Autauga County' 
order by 1;
## → Inspect a specific county with a known place-name mismatch

UPDATE us_household_income
SET place = 'Autaugaville' 
WHERE county = 'Autauga County' 
AND city = 'Vinemont';
## → Correct place name for a city that was mis-mapped to Vinemont

################################################################################
# 5. HARMONIZE AREA TYPE VALUES
################################################################################

SELECT type, COUNT(type)
From us_project.us_household_income
GROUP BY type;
## → See all unique 'type' values: City, CDP, Borough, Boroughs, Community, etc.

UPDATE us_household_income
SET type = 'Borough'
WHERE type = 'Boroughs';
