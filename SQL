# 8. EXPLORATORY DATA ANALYSIS (EDA)
################################################################################

Select *
From us_household_income_statistics;
SELECT *
FROM us_household_income;
## → Final sanity check before joining

--------------------------------------------------------------------------------
# 8.1 LAND & WATER BY STATE
--------------------------------------------------------------------------------

SELECT State_Name, SUM(ALand) AS total_land, SUM(Awater) AS total_water
FROM us_project.us_household_income
GROUP BY State_Name
ORDER BY 2 DESC;
## → Largest land mass: TX, CA, MI

SELECT State_Name, SUM(ALand) AS total_land, SUM(Awater) AS total_water
FROM us_project.us_household_income
GROUP BY State_Name
ORDER BY 3 DESC;
## → Largest water mass: AK, FL, LA

SELECT State_Name, SUM(ALand) AS total_land, SUM(Awater) AS total_water
FROM us_project.us_household_income
GROUP BY State_Name
ORDER BY 2 DESC
LIMIT 10;
## → Top 10 states by land (change ORDER BY 3 for top 10 by water)

--------------------------------------------------------------------------------
# 8.2 JOIN GEOGRAPHY + INCOME
--------------------------------------------------------------------------------

SELECT * 
FROM us_household_income u
JOIN us_household_income_statistics us
   ON u.id = us.id;
## → Inner join: only matching ids (most common analysis view)

SELECT * 
FROM us_household_income u
RIGHT JOIN us_household_income_statistics us
   ON u.id = us.id 
WHERE u.id IS NULL;
## → Right join test: find income rows with NO geography (missing data)
## → Many rows here → decide to exclude or fix source Excel

SELECT * 
FROM us_project.us_household_income u
INNER JOIN us_project.us_household_income_statistics us
   ON u.id = us.id
WHERE mean <> 0;
## → Filter out unreported / suppressed income (mean = 0)

SELECT u.State_Name, County, Type, `Primary`, mean, median
FROM us_project.us_household_income u
INNER JOIN us_project.us_household_income_statistics us    
   ON u.id = us.id
WHERE mean <> 0;
## → Core working set: categorical + income metrics

--------------------------------------------------------------------------------
# 8.3 STATE-LEVEL INCOME RANKINGS
--------------------------------------------------------------------------------

SELECT u.State_Name, AVG(mean) AS avg_mean, AVG(median) AS avg_median
FROM us_project.us_household_income u
INNER JOIN us_project.us_household_income_statistics us    
   ON u.id = us.id
WHERE mean <> 0
GROUP BY u.State_Name;
## → Raw averages (will be rounded next)

SELECT u.State_Name, 
       ROUND(AVG(mean),1) AS avg_mean, 
       ROUND(AVG(median),1) AS avg_median
FROM us_project.us_household_income u
INNER JOIN us_project.us_household_income_statistics us    
   ON u.id = us.id
WHERE mean <> 0
GROUP BY u.State_Name
ORDER BY 2 ASC;
## → Lowest → highest mean income by state
## → Limit 5 to see the 5 poorest states

SELECT u.State_Name, 
       ROUND(AVG(mean),1) AS avg_mean, 
       ROUND(AVG(median),1) AS avg_median
FROM us_project.us_household_income u
INNER JOIN us_project.us_household_income_statistics us    
   ON u.id = us.id
WHERE mean <> 0
GROUP BY u.State_Name
ORDER BY 2 DESC
LIMIT 20;
## → Top 20 richest states by mean income

SELECT u.State_Name, 
       ROUND(AVG(mean),1) AS avg_mean, 
       ROUND(AVG(median),1) AS avg_median
FROM us_project.us_household_income u
INNER JOIN us_project.us_household_income_statistics us    
   ON u.id = us.id
WHERE mean <> 0
GROUP BY u.State_Name
ORDER BY 3 DESC
LIMIT 20;
## → Top 20 by median income (often more stable than mean)

SELECT u.State_Name, 
       ROUND(AVG(mean),1) AS avg_mean, 
       ROUND(AVG(median),1) AS avg_median
FROM us_project.us_household_income u
INNER JOIN us_project.us_household_income_statistics us    
   ON u.id = us.id
WHERE mean <> 0
GROUP BY u.State_Name
ORDER BY 3 DESC
LIMIT 10;
## → Highest median: best view of “typical” high-earning states

--------------------------------------------------------------------------------
# 8.4 INCOME BY AREA TYPE (City, CDP, Borough, Community, etc.)
--------------------------------------------------------------------------------

SELECT type, 
       ROUND(AVG(mean),1) AS avg_mean, 
       ROUND(AVG(median),1) AS avg_median
FROM us_project.us_household_income u
INNER JOIN us_project.us_household_income_statistics us    
   ON u.id = us.id
WHERE mean <> 0
GROUP BY type
ORDER BY 2 DESC;
## → Which area types earn the most (Cities & Boroughs top)

SELECT type, 
       COUNT(type) AS count,
       ROUND(AVG(mean),1) AS avg_mean, 
       ROUND(AVG(median),1) AS avg_median
FROM us_project.us_household_income u
INNER JOIN us_project.us_household_income_statistics us    
   ON u.id = us.id
WHERE mean <> 0
GROUP BY 1 
ORDER BY 3 DESC;
## → Add counts to confirm sample size per type

SELECT type, 
       COUNT(type) AS count,
       ROUND(AVG(mean),1) AS avg_mean, 
       ROUND(AVG(median),1) AS avg_median
FROM us_project.us_household_income u
INNER JOIN us_project.us_household_income_statistics us    
   ON u.id = us.id
WHERE mean <> 0
GROUP BY 1 
ORDER BY 4 DESC;
## → Rank by median instead (shows which types have highest “typical” income)

Select * 
from us_household_income                  
where type = 'Community';
## → Inspect low-income 'Community' rows (often Puerto Rico & rural areas)

SELECT type, 
       COUNT(type) AS count,
       ROUND(AVG(mean),1) AS avg_mean, 
       ROUND(AVG(median),1) AS avg_median
FROM us_project.us_household_income u
INNER JOIN us_project.us_household_income_statistics us    
   ON u.id = us.id
WHERE mean <> 0
GROUP BY 1 
HAVING COUNT(type) > 100
ORDER BY 4 DESC;
## → Filter out rare types (count ≤ 100) to focus on robust comparisons

--------------------------------------------------------------------------------
# 8.5 RICHEST CITIES BY STATE
--------------------------------------------------------------------------------

select * 
from us_project.us_household_income u
JOIN us_project.us_household_income_statistics us 
       ON u.id = us.id;
## → Base join for city-level analysis

select u.State_Name, city, ROUND(AVG(MEAN),1) AS avg_mean
from us_project.us_household_income u
JOIN us_project.us_household_income_statistics us 
       ON u.id = us.id 
GROUP BY u.state_name, city;
## → Avg mean income by state + city (unsorted)

select u.State_Name, city, ROUND(AVG(MEAN),1) AS avg_mean
from us_project.us_household_income u
JOIN us_project.us_household_income_statistics us 
       ON u.id = us.id 
GROUP BY u.state_name, city
ORDER BY 3 DESC;
## → Rank all cities by mean income (richest first)

select u.State_Name, city, 
       ROUND(AVG(MEAN),1) AS avg_mean, 
       ROUND(AVG(median),1) AS avg_median
from us_project.us_household_income u
JOIN us_project.us_household_income_statistics us 
       ON u.id = us.id 
GROUP BY u.state_name, city
ORDER BY 3 DESC;
